# Copy this over to `.env` in the same directory as this file
# and fill out the variables with the correct values.
#
TOKEN=your_bot_token_here

# postgres db variables
PGPASSWORD=password
PGUSER=postgres
PGHOST=database
PGPORT=5432
PGDATABASE=hangbot

# DO NOT replace `localhost` with `PGHOST` here. This var is for db migrations and requires localhost.
DATABASE_URL="postgres://${PGUSER}:${PGPASSWORD}@localhost:${PGPORT}/${PGDATABASE}"
