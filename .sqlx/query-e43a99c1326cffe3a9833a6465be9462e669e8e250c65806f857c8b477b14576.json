{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT me.*\n                FROM meetup_events AS me\n                INNER JOIN meetup_groups_guilds AS mgg\n                ON me.meetup_group_name = mgg.group_name\n                WHERE me.duplicate_event_hash = $1\n                AND mgg.guild_id = $2\n                ORDER BY me.start_time ASC, me.meetup_group_name ASC\n            ",
